# Copy to infra/config.env and fill in before running deploy scripts.
# config.env is gitignored — never commit secrets.

AWS_REGION=us-west-2
AWS_ACCOUNT_ID=123456789012

# DynamoDB
DYNAMO_TABLE_NAME=PortfolioData
PROFILE_PK=PROFILE#ethan-harter

# Lambda
LAMBDA_FUNCTION_NAME=PortfolioChat
LAMBDA_ROLE_NAME=PortfolioChatRole

# Bedrock (Haiku 4.5 — cheapest; inference profile prefix added in code)
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MAX_TOKENS=1024

# API Gateway
API_NAME=PortfolioChatApi

# Frontend hosting
S3_BUCKET=ethan-portfolio-frontend-123456789012
CLOUDFRONT_COMMENT=Ethan Portfolio Frontend

# Your live site origin for CORS (no trailing slash)
FRONTEND_ORIGIN=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net
